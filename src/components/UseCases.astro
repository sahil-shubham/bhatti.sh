---
const useCases = [
    {
        title: "Build on it",
        description: "REST API with multi-tenant auth, rate limiting, and network isolation. Create machines programmatically, run work, publish URLs — the compute layer for your platform.",
        code: `<span class="c"># Create a machine from a custom image</span>
$ curl -X POST /sandboxes \\
    -H "Authorization: Bearer bht_..." \\
    -d '{"name":"task-42","image":"my-stack"}'

<span class="c"># Run a command, stream output</span>
$ curl -N -H "Accept: application/x-ndjson" \\
    -d '{"cmd":["mix","test"]}' \\
    /sandboxes/task-42/exec

<span class="c"># Publish a port to the internet</span>
$ bhatti publish task-42 -p 4000 -a dashboard
<span class="c">→ https://dashboard.bhatti.sh</span>`
    },
    {
        title: "Freeze and resume anything",
        description: "Snapshot captures running processes, memory, TCP connections — not just files. Restore brings the machine back alive exactly where it left off.",
        code: `<span class="c"># Server running, counter at 2</span>
$ bhatti exec dev -- curl -s localhost:3000
{"visits":2}

<span class="c"># Snapshot everything</span>
$ bhatti snapshot create dev --name checkpoint
✓ Saved in 2.0s

<span class="c"># Break it, restore it</span>
$ bhatti exec dev -- pkill -f node
$ bhatti snapshot resume checkpoint --name dev
✓ Restored in 510ms

$ bhatti exec dev -- curl -s localhost:3000
{"visits":3}  <span class="c"># process alive, state intact</span>`
    },
    {
        title: "Your images. Your fleet.",
        description: "Install your stack once, save as an image, stamp out machines from it. Idle ones sleep automatically — run 50 machines on hardware that fits 10.",
        code: `<span class="c"># Build a custom image</span>
$ bhatti create --name build --image minimal
$ bhatti exec build -- apt-get install -y nodejs
$ bhatti image save build --name node-app

<span class="c"># Stamp out machines from it</span>
$ bhatti create --name worker-1 --image node-app
$ bhatti create --name worker-2 --image node-app

$ bhatti list
<span class="c">NAME       THERMAL   MEMORY    UPTIME</span>
worker-1   hot       1024MB    2m
worker-2   hot       1024MB    1m
build      cold        —       1h`
    },
];
---

<section id="use-cases">
    <div class="container">
        <span class="system-label">CAPABILITIES</span>
        <h2 class="section-heading mb-64">What you can do with it</h2>

        <div class="use-case-grid">
            {useCases.map(uc => (
                <div class="code-panel">
                    <div class="code-panel-text">
                        <h3>{uc.title}</h3>
                        <p>{uc.description}</p>
                    </div>
                    <pre class="code-panel-pre"><code set:html={uc.code} /></pre>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .use-case-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 24px;
    }

    .c {
        color: var(--zinc-500);
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .use-case-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>
