---
// Pulled from `bhatti --help` for v1.11.0 (May 2026). If you change the
// CLI surface, update this list. The CLI Reference docs are the
// canonical per-command details.
const commands = [
    // Sandbox lifecycle
    { cmd: "create", args: "<name>", flags: "[--cpus N] [--memory MB] [--image NAME] [--init CMD] [--env K=V] [--volume V:/mnt] [--secret K] [--file local:guest] [--keep-hot] [--hugepages]", desc: "Create a new machine" },
    { cmd: "destroy", args: "<name>", flags: "[-y]", desc: "Destroy a machine (alias: rm)" },
    { cmd: "edit", args: "<name>", flags: "[--keep-hot] [--allow-cold]", desc: "Update machine settings" },
    { cmd: "list", args: "", flags: "[-o wide]", desc: "List your machines (alias: ls)" },
    { cmd: "inspect", args: "<name>", flags: "", desc: "Show machine details (alias: info)" },
    { cmd: "start", args: "<name>", flags: "[--force]", desc: "Resume a stopped machine" },
    { cmd: "stop", args: "<name>", flags: "", desc: "Snapshot and stop a machine" },
    { divider: "Execution & shells" },
    { cmd: "exec", args: "<name> -- <cmd>", flags: "[--timeout S] [--detach]", desc: "Run a command" },
    { cmd: "shell", args: "<name>", flags: "[--new]", desc: "Interactive terminal (Ctrl+\\ to detach)" },
    { cmd: "ps", args: "<name>", flags: "", desc: "List active sessions in a machine" },
    { cmd: "ports", args: "<name>", flags: "", desc: "List listening TCP ports inside a machine" },
    { divider: "Files & Secrets" },
    { cmd: "file read", args: "<name> <path>", flags: "", desc: "Read a file" },
    { cmd: "file write", args: "<name> <path>", flags: "< stdin", desc: "Write a file (atomic)" },
    { cmd: "file ls", args: "<name> <path>", flags: "", desc: "List a directory" },
    { cmd: "secret set", args: "<key> <value>", flags: "", desc: "Store an encrypted secret" },
    { cmd: "secret list", args: "", flags: "", desc: "List secret names" },
    { cmd: "secret delete", args: "<key>", flags: "", desc: "Delete a secret" },
    { divider: "Images" },
    { cmd: "image list", args: "", flags: "", desc: "List available images" },
    { cmd: "image pull", args: "<ref>", flags: "[--name N] [--auth U:T]", desc: "Pull an OCI image from a public registry" },
    { cmd: "image import", args: "<docker-ref> | --tar <path>", flags: "[--name N]", desc: "Import from local Docker or a tarball" },
    { cmd: "image save", args: "<sandbox>", flags: "--name <image>", desc: "Save a running machine's rootfs as a reusable image" },
    { cmd: "image delete", args: "<name>", flags: "[-y]", desc: "Delete an image" },
    { cmd: "image share", args: "<image>", flags: "--user <name>...", desc: "Share an image with specific users (server-only)" },
    { cmd: "image unshare", args: "<image>", flags: "--user <name>...", desc: "Revoke image access (server-only)" },
    { divider: "Snapshots" },
    { cmd: "snapshot create", args: "<sandbox>", flags: "--name <snap>", desc: "Checkpoint a running machine (memory + processes + disk)" },
    { cmd: "snapshot list", args: "", flags: "", desc: "List snapshots" },
    { cmd: "snapshot resume", args: "<snap>", flags: "[--name <new>]", desc: "Resume a snapshot into a new machine" },
    { cmd: "snapshot delete", args: "<snap>", flags: "[-y]", desc: "Delete a snapshot" },
    { divider: "Networking & Publishing" },
    { cmd: "publish", args: "<name>", flags: "-p <port> [-a <alias>] [--shell]", desc: "Publish a port → https://alias.bhatti.sh" },
    { cmd: "unpublish", args: "<name>", flags: "-p <port>", desc: "Remove a published port" },
    { cmd: "share", args: "<name>", flags: "[--revoke]", desc: "Generate a web shell URL" },
    { divider: "Volumes" },
    { cmd: "volume create", args: "", flags: "--name <v> --size <MB>", desc: "Create a persistent volume" },
    { cmd: "volume list", args: "", flags: "", desc: "List volumes" },
    { cmd: "volume delete", args: "<name>", flags: "[-y]", desc: "Delete a volume" },
    { cmd: "volume resize", args: "<name>", flags: "--size <MB>", desc: "Resize a volume (grow only)" },
    { cmd: "volume clone", args: "<src>", flags: "--name <new>", desc: "Clone a volume (point-in-time copy)" },
    { cmd: "volume backup", args: "<name>", flags: "", desc: "Back up a volume to S3-compatible storage" },
    { cmd: "volume backup-list", args: "<name>", flags: "", desc: "List backups for a volume" },
    { cmd: "volume restore", args: "<name>", flags: "--backup-id <id>", desc: "Restore a volume from a backup" },
    { cmd: "volume backup-delete", args: "<name> <id>", flags: "[-y]", desc: "Delete a volume backup" },
    { divider: "Server & admin" },
    { cmd: "serve", args: "", flags: "", desc: "Start the daemon (server-only)" },
    { cmd: "setup", args: "", flags: "", desc: "Configure CLI endpoint + API key" },
    { cmd: "version", args: "", flags: "", desc: "Print version, check for updates" },
    { cmd: "update", args: "", flags: "[--cli-only] [--tiers <list>]", desc: "Update bhatti" },
    { cmd: "completion", args: "<bash|zsh|fish>", flags: "", desc: "Generate a shell completion script" },
    { cmd: "user create", args: "", flags: "--name <u> [--max-sandboxes N] [--max-cpus N] [--max-memory MB]", desc: "Create a user (server-only)" },
    { cmd: "user list", args: "", flags: "", desc: "List users (server-only)" },
    { cmd: "user rotate-key", args: "<name>", flags: "", desc: "Rotate a user's API key (server-only)" },
    { cmd: "user delete", args: "<name>", flags: "[-y]", desc: "Delete a user (server-only)" },
    { cmd: "admin status", args: "", flags: "", desc: "One-shot system overview (server-only)" },
    { cmd: "admin events", args: "", flags: "[--type T] [--since 24h] [--user U] [--sandbox S]", desc: "Query the event log (server-only)" },
    { cmd: "admin metrics", args: "", flags: "[--since 1h]", desc: "Query metrics snapshots (server-only)" },
];
---

<section id="cli">
    <div class="container">
        <span class="system-label">CLI</span>
        <h2 class="section-heading mb-16">Every command</h2>
        <p class="section-sub mb-48">Single binary. <code class="inline-code">bhatti serve</code> starts the daemon, everything else talks to its API.</p>

        <div class="cli-table">
            {commands.map(entry => (
                'divider' in entry ? (
                    <div class="cli-divider">{entry.divider}</div>
                ) : (
                    <div class="cli-row">
                        <div class="cli-cmd">
                            <span class="cmd-name">bhatti {entry.cmd}</span>
                            {entry.args && <span class="cmd-args">{entry.args}</span>}
                            {entry.flags && <span class="cmd-flags">{entry.flags}</span>}
                        </div>
                        <div class="cli-desc">{entry.desc}</div>
                    </div>
                )
            ))}
        </div>

        <p class="cli-footer">All commands support <code class="inline-code">--json</code> for scripting and <code class="inline-code">--timing</code> for performance debugging.</p>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .section-sub {
        color: var(--zinc-400);
        font-size: 1rem;
    }

    .mb-16 { margin-bottom: 16px; }
    .mb-48 { margin-bottom: 48px; }

    .inline-code {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--zinc-900);
        border: 1px solid var(--zinc-800);
        border-radius: 3px;
        padding: 2px 6px;
        color: var(--zinc-300);
    }

    .cli-table {
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        background: var(--zinc-900);
        overflow: hidden;
    }

    .cli-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: baseline;
        padding: 10px 20px;
        border-bottom: 1px solid var(--zinc-800);
    }

    .cli-row:last-child {
        border-bottom: none;
    }

    .cli-divider {
        padding: 8px 20px;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--amber-500);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        background: rgba(249, 115, 22, 0.03);
        border-bottom: 1px solid var(--zinc-800);
    }

    .cli-divider + .cli-row:last-child,
    .cli-row:has(+ .cli-divider) {
        border-bottom: none;
    }

    .cli-cmd {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: baseline;
    }

    .cmd-name {
        color: var(--zinc-50);
        font-weight: 500;
    }

    .cmd-args {
        color: var(--zinc-300);
    }

    .cmd-flags {
        color: var(--zinc-500);
    }

    .cli-desc {
        font-size: 0.8125rem;
        color: var(--zinc-400);
        text-align: right;
        white-space: nowrap;
    }

    .cli-footer {
        margin-top: 20px;
        font-size: 0.8125rem;
        color: var(--zinc-500);
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .cli-row {
            grid-template-columns: 1fr;
            gap: 4px;
            padding: 8px 14px;
        }

        .cli-desc {
            text-align: left;
            font-size: 0.75rem;
        }

        .cli-cmd {
            font-size: 0.75rem;
        }

        .cli-divider {
            padding: 6px 14px;
            font-size: 0.625rem;
        }
    }
</style>
