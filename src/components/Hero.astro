---
import HeroTerminal from './HeroTerminal.astro';
---

<section class="hero">
    <div class="container hero-layout">
        <div class="hero-content">
            <h1>Your metal. Machines on demand.</h1>
            <p class="subhead">
                Real Linux VMs that manage themselves. Create in seconds, snapshot everything, resume in milliseconds. On your hardware, open source.
            </p>

            <div class="hero-actions">
                <div class="copy-block">
                    <code id="install-cmd">curl -fsSL bhatti.sh/install | bash</code>
                    <button class="copy-btn" data-copy="install-cmd">Copy</button>
                </div>
                <a href="https://github.com/sahil-shubham/bhatti" target="_blank" rel="noopener" class="btn btn-outline">
                    GitHub →
                </a>
            </div>
        </div>

        <HeroTerminal />
    </div>
</section>

<style>
    .hero {
        padding-top: 140px;
        padding-bottom: 60px;
    }

    .hero::before { display: none; }

    .hero-layout {
        display: grid;
        grid-template-columns: 5fr 7fr;
        gap: 48px;
        align-items: start;
    }

    .hero-layout > * {
        min-width: 0;
    }

    .hero-content {
        display: flex;
        flex-direction: column;
        gap: 20px;
        padding-top: 4px; /* optical alignment with terminal chrome */
    }

    .hero h1 {
        font-size: clamp(2rem, 3.2vw, 2.75rem);
        color: var(--zinc-50);
    }

    .hero .subhead {
        font-size: 0.9375rem;
        color: var(--zinc-400);
        line-height: 1.6;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    @media (max-width: 768px) {
        .hero {
            padding-top: 100px;
        }

        .hero-layout {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .hero h1 {
            font-size: 2rem;
        }

        .hero-actions {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

<script>
    document.querySelectorAll('[data-copy]').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.copy;
            if (!id) return;
            const el = document.getElementById(id);
            if (!el) return;
            navigator.clipboard.writeText(el.innerText).then(() => {
                const orig = btn.textContent;
                btn.textContent = 'Copied!';
                (btn as HTMLElement).style.color = 'var(--zinc-50)';
                setTimeout(() => { btn.textContent = orig; (btn as HTMLElement).style.color = ''; }, 2000);
            });
        });
    });
</script>
