---
const links = [
    { label: "Docs", href: "/docs/quickstart/" },
    { label: "GitHub", href: "https://github.com/sahil-shubham/bhatti", id: "gh-link", external: true },
];

let buildTimeStars: number | null = null;
try {
    const res = await fetch('https://api.github.com/repos/sahil-shubham/bhatti');
    const data = await res.json();
    buildTimeStars = data.stargazers_count ?? null;
} catch {}
---

<nav id="navbar">
    <div class="container nav-inner">
        <a href="/" class="logo">[bhatti]</a>
        <div class="nav-links">
            {links.map(link => (
                <a
                    href={link.href}
                    {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
                    id={link.id}
                >{link.label}{link.id === 'gh-link' && <span class:list={['gh-stars', { loaded: buildTimeStars != null }]} id="gh-stars">{buildTimeStars != null ? `★ ${buildTimeStars}` : ''}</span>}</a>
            ))}
            <a href="#get-started" class="btn btn-amber">Get Started</a>
        </div>

        <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
            <span></span>
            <span></span>
        </button>
    </div>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-links">
        {links.map(link => (
            <a
                href={link.href}
                {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
            >{link.label}</a>
        ))}
        <a href="#get-started" class="btn btn-amber" style="width: 100%; margin-top: 8px;">Get Started</a>
    </div>
</div>

<style>
    nav {
        position: fixed;
        top: 0;
        width: 100%;
        height: var(--nav-height);
        z-index: 100;
        display: flex;
        align-items: center;
        transition: background-color 0.3s ease, border-bottom-color 0.3s ease;
        border-bottom: 1px solid transparent;
    }

    nav.scrolled {
        background-color: rgba(9, 9, 11, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom-color: var(--zinc-800);
    }

    .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .logo {
        font-family: var(--font-mono);
        font-weight: 600;
        font-size: 1.125rem;
        text-decoration: none;
        color: var(--zinc-50);
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .nav-links a:not(.btn) {
        color: var(--zinc-400);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s;
    }

    .nav-links a:not(.btn):hover {
        color: var(--zinc-50);
    }

    .mobile-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
    }

    .mobile-toggle span {
        display: block;
        width: 20px;
        height: 1.5px;
        background: var(--zinc-400);
        transition: transform 0.2s, opacity 0.2s;
    }

    .mobile-menu {
        display: none;
        position: fixed;
        top: var(--nav-height);
        left: 0;
        right: 0;
        z-index: 99;
        background: rgba(9, 9, 11, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--zinc-800);
        padding: 24px;
    }

    .mobile-menu.open {
        display: block;
    }

    .mobile-menu-links {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .mobile-menu-links a:not(.btn) {
        color: var(--zinc-400);
        font-size: 1rem;
        text-decoration: none;
    }

    .gh-stars {
        font-size: 0.75rem;
        margin-left: 6px;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .gh-stars.loaded {
        opacity: 1;
    }

    @media (max-width: 768px) {
        .nav-links {
            display: none;
        }

        .mobile-toggle {
            display: flex;
        }
    }
</style>

<script>
    // Scroll effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            navbar?.classList.add('scrolled');
        } else {
            navbar?.classList.remove('scrolled');
        }
    });

    // Mobile menu
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
        menu?.classList.toggle('open');
    });

    // Close mobile menu on link click
    menu?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
            menu?.classList.remove('open');
        });
    });

    // Client-side fallback for GitHub stars (build-time fetch may fail in CI)
    const starsEl = document.getElementById('gh-stars');
    if (starsEl && !starsEl.classList.contains('loaded')) {
        fetch('https://api.github.com/repos/sahil-shubham/bhatti')
            .then(r => r.json())
            .then(data => {
                if (data.stargazers_count != null) {
                    starsEl.textContent = `★ ${data.stargazers_count}`;
                    starsEl.classList.add('loaded');
                }
            })
            .catch(() => {});
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
            e.preventDefault();
            const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
            if (!href) return;
            const target = document.querySelector(href);
            if (target) {
                const offset = 80;
                const top = target.getBoundingClientRect().top + window.pageYOffset - offset;
                window.scrollTo({ top, behavior: 'smooth' });
            }
        });
    });
</script>
