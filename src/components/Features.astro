---
const facts = [
    {
        number: "01",
        title: "Real VMs. Not containers.",
        description: "Every machine runs its own Linux kernel. Separate filesystem, separate network, separate process space. Not a namespace trick — a separate computer."
    },
    {
        number: "02",
        title: "Snapshot everything. Not just files.",
        description: "When bhatti snapshots a machine, it captures everything: running processes, open file descriptors, TCP connections, in-memory state. Resume picks up exactly where it left off."
    },
    {
        number: "03",
        title: "Idle machines cost nothing.",
        description: "Idle machines pause their CPUs automatically. Left idle longer, they snapshot to disk and free all memory. Any request wakes them transparently — you never manage this."
    }
];

// Numbers measured on agni-01 (Hetzner AX102, btrfs storage, x86_64, NVMe)
// running bhatti v1.11.0. Reproduce with `bench/run.sh` in the repo.
//
// All rows are CLI wall-clock except "Wake on request" — that's HTTP
// wall-clock against a published port (curl), since published URLs are
// HTTP-only. Both methodologies measure on the same host as the daemon,
// so geographic network latency isn't included; add your RTT for remote use.
//
// We show p50 (typical) and p99 (tail) only. p95 was redundant with p99
// at our sample sizes — same value or one sample apart. The pair P50/P99
// communicates distribution shape without third-column noise.
const benchmarks = [
    { op: "Create a machine",          p50: "268ms",   p99: "278ms" },
    { op: "Snapshot to disk (512MB)",  p50: "505ms",   p99: "577ms" },
    { op: "Resume from disk",          p50: "75ms",    p99: "77ms" },
    { op: "Wake on request (cold)",    p50: "60ms",    p99: "76ms" },
    { op: "Wake on request (warm)",    p50: "4.3ms",   p99: "22.6ms" },
    { op: "Destroy a machine",         p50: "93ms",    p99: "98ms" },
    { op: "Run a command",             p50: "12ms",    p99: "17ms" },
    { op: "20 commands in parallel",   p50: "34ms",    p99: "36ms" },
];
---

<section id="features">
    <div class="container grid-2">
        <div>
            <span class="system-label">CORE</span>
            <h2 class="section-heading mb-64">Real machines. Zero waste.</h2>

            <div class="facts-list">
                {facts.map(fact => (
                    <div class="fact-item">
                        <div class="fact-number">{fact.number}</div>
                        <div class="fact-content">
                            <h3>{fact.title}</h3>
                            <p>{fact.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <div>
            <span class="system-label" style="text-align: right;">SYS.PERFORMANCE // LATENCY</span>
            <div class="table-container mb-16">
                <table>
                    <thead>
                        <tr>
                            <th>Operation</th>
                            <th>p50</th>
                            <th>p99</th>
                        </tr>
                    </thead>
                    <tbody class="mono">
                        {benchmarks.map(b => (
                            <tr>
                                <td class="op-cell">{b.op}</td>
                                <td>{b.p50}</td>
                                <td>{b.p99}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-muted bench-note">
        Hetzner AX102, btrfs, bhatti v1.11.0, CLI on the daemon host.<br />
        Reproduce: <code>bench/run.sh</code>.
    </p>
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .facts-list {
        display: flex;
        flex-direction: column;
        gap: 48px;
    }

    .fact-item {
        display: grid;
        grid-template-columns: 24px 1fr;
        gap: 24px;
        align-items: baseline;
    }

    .fact-number {
        font-family: var(--font-mono);
        color: var(--amber-500);
        font-size: 0.875rem;
    }

    .fact-content h3 {
        font-size: 1.5rem;
        margin-bottom: 12px;
    }

    .fact-content p {
        color: var(--zinc-400);
    }

    .table-container {
        width: 100%;
        overflow-x: auto;
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        background: var(--zinc-900);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    th, td {
        padding: 16px;
        border-bottom: 1px solid var(--zinc-800);
        font-size: 0.875rem;
    }

    th {
        font-family: var(--font-mono);
        font-weight: 400;
        color: var(--zinc-400);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }

    td {
        font-variant-numeric: tabular-nums;
    }

    .op-cell {
        font-family: var(--font-sans) !important;
    }

    th:nth-child(n+2), td:nth-child(n+2) {
        text-align: right;
    }

    tr:last-child td { border-bottom: none; }

    .bench-note {
        text-align: right;
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .fact-content h3 { font-size: 1.25rem; }
        .facts-list { gap: 32px; }

        .table-container {
            border-radius: 0;
        }

        th, td {
            padding: 10px 12px;
            font-size: 0.75rem;
        }

        .bench-note {
            text-align: left;
        }
    }
</style>
