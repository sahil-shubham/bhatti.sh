---
const facts = [
    {
        number: "01",
        title: "Real VMs. Not containers.",
        description: "Every machine runs its own Linux kernel. Separate filesystem, separate network, separate process space. Not a namespace trick — a separate computer."
    },
    {
        number: "02",
        title: "Snapshot everything. Not just files.",
        description: "When bhatti snapshots a machine, it captures everything: running processes, open file descriptors, TCP connections, in-memory state. Resume picks up exactly where it left off."
    },
    {
        number: "03",
        title: "Idle machines cost nothing.",
        description: "Idle machines pause their CPUs automatically. Left idle longer, they snapshot to disk and free all memory. Any request wakes them transparently — you never manage this."
    }
];

const benchmarks = [
    { op: "Run a command", p50: "1.07ms", p95: "1.58ms", p99: "1.63ms" },
    { op: "Read a file (1KB)", p50: "503µs", p95: "675µs", p99: "747µs" },
    { op: "Write a file (1KB)", p50: "1.07ms", p95: "1.22ms", p99: "1.58ms" },
    { op: "Command on paused machine", p50: "2.14ms", p95: "11.1ms", p99: "11.1ms" },
    { op: "Command on cold machine", p50: "42.2ms", p95: "44.0ms", p99: "44.0ms" },
    { op: "10 commands at once", p50: "12.0ms", p95: "20.0ms", p99: "20.0ms" },
    { op: "Create a machine", p50: "272ms", p95: "302ms", p99: "302ms" },
    { op: "Full snapshot (512MB)", p50: "621ms", p95: "655ms", p99: "655ms" },
];
---

<section id="features">
    <div class="container grid-2">
        <div>
            <span class="system-label">CORE</span>
            <h2 class="section-heading mb-64">Real machines. Zero waste.</h2>

            <div class="facts-list">
                {facts.map(fact => (
                    <div class="fact-item">
                        <div class="fact-number">{fact.number}</div>
                        <div class="fact-content">
                            <h3>{fact.title}</h3>
                            <p>{fact.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <div>
            <span class="system-label" style="text-align: right;">SYS.PERFORMANCE // LATENCY</span>
            <div class="table-container mb-16">
                <table>
                    <thead>
                        <tr>
                            <th>Operation</th>
                            <th>p50</th>
                            <th>p95</th>
                            <th>p99</th>
                        </tr>
                    </thead>
                    <tbody class="mono">
                        {benchmarks.map(b => (
                            <tr>
                                <td class="op-cell">{b.op}</td>
                                <td>{b.p50}</td>
                                <td>{b.p95}</td>
                                <td>{b.p99}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-muted bench-note">Measured on Hetzner AX102 (AMD Ryzen 9, x86_64, NVMe). Pi 5 numbers in the repo README.</p>
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .facts-list {
        display: flex;
        flex-direction: column;
        gap: 48px;
    }

    .fact-item {
        display: grid;
        grid-template-columns: 24px 1fr;
        gap: 24px;
        align-items: baseline;
    }

    .fact-number {
        font-family: var(--font-mono);
        color: var(--amber-500);
        font-size: 0.875rem;
    }

    .fact-content h3 {
        font-size: 1.5rem;
        margin-bottom: 12px;
    }

    .fact-content p {
        color: var(--zinc-400);
    }

    .table-container {
        width: 100%;
        overflow-x: auto;
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        background: var(--zinc-900);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    th, td {
        padding: 16px;
        border-bottom: 1px solid var(--zinc-800);
        font-size: 0.875rem;
    }

    th {
        font-family: var(--font-mono);
        font-weight: 400;
        color: var(--zinc-400);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }

    td {
        font-variant-numeric: tabular-nums;
    }

    .op-cell {
        font-family: var(--font-sans) !important;
    }

    th:nth-child(n+2), td:nth-child(n+2) {
        text-align: right;
    }

    tr:last-child td { border-bottom: none; }

    .bench-note {
        text-align: right;
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .fact-content h3 { font-size: 1.25rem; }
        .facts-list { gap: 32px; }

        .table-container {
            border-radius: 0;
        }

        th, td {
            padding: 10px 12px;
            font-size: 0.75rem;
        }

        .bench-note {
            text-align: left;
        }
    }
</style>
