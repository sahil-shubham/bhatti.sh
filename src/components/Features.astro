---
const facts = [
    {
        number: "01",
        title: "Real VMs. Not containers.",
        description: "Every sandbox runs its own Linux kernel in a Firecracker microVM. Process isolation, filesystem isolation, network isolation. Not a namespace trick — a separate machine."
    },
    {
        number: "02",
        title: "Memory snapshots. Not just filesystem.",
        description: "When bhatti snapshots a VM, it captures everything: running processes, open file descriptors, TCP connections, in-memory state. Resume picks up exactly where it left off."
    },
    {
        number: "03",
        title: "Three thermal states. Invisible to you.",
        description: "Idle 30 seconds → warm (vCPUs paused, ~400µs resume). Idle 30 minutes → cold (snapshotted to disk, memory freed, ~50ms resume). Any API request transparently wakes it."
    }
];

const benchmarks = [
    { op: "Exec (single command)", p50: "1.0ms", p95: "1.2ms", p99: "1.3ms" },
    { op: "File read (1KB)", p50: "472µs", p95: "826µs", p99: "881µs" },
    { op: "Resume + exec (warm)", p50: "2.5ms", p95: "2.6ms", p99: "2.6ms" },
    { op: "10 concurrent execs", p50: "18ms", p95: "19ms", p99: "19ms" },
    { op: "VM boot (cold start)", p50: "~3.5s", p95: "—", p99: "—" },
    { op: "Diff snapshot", p50: "~52ms", p95: "—", p99: "—" },
    { op: "Pause / Resume", p50: "~400µs", p95: "—", p99: "—" },
];
---

<section id="features">
    <div class="container grid-2">
        <div>
            <span class="system-label">CORE.PRIMITIVES</span>
            <h2 class="section-heading mb-64">Isolation without the overhead.</h2>

            <div class="facts-list">
                {facts.map(fact => (
                    <div class="fact-item">
                        <div class="fact-number">{fact.number}</div>
                        <div class="fact-content">
                            <h3>{fact.title}</h3>
                            <p>{fact.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <div>
            <span class="system-label" style="text-align: right;">SYS.PERFORMANCE // LATENCY</span>
            <div class="table-container mb-16">
                <table>
                    <thead>
                        <tr>
                            <th>Operation</th>
                            <th>p50</th>
                            <th>p95</th>
                            <th>p99</th>
                        </tr>
                    </thead>
                    <tbody class="mono">
                        {benchmarks.map(b => (
                            <tr>
                                <td class="op-cell">{b.op}</td>
                                <td>{b.p50}</td>
                                <td>{b.p95}</td>
                                <td>{b.p99}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-muted bench-note">Measured on a Raspberry Pi 5 (ARM64) with NVMe storage.</p>
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .facts-list {
        display: flex;
        flex-direction: column;
        gap: 48px;
    }

    .fact-item {
        display: grid;
        grid-template-columns: 24px 1fr;
        gap: 24px;
        align-items: baseline;
    }

    .fact-number {
        font-family: var(--font-mono);
        color: var(--amber-500);
        font-size: 0.875rem;
    }

    .fact-content h3 {
        font-size: 1.5rem;
        margin-bottom: 12px;
    }

    .fact-content p {
        color: var(--zinc-400);
    }

    .table-container {
        width: 100%;
        overflow-x: auto;
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        background: var(--zinc-900);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    th, td {
        padding: 16px;
        border-bottom: 1px solid var(--zinc-800);
        font-size: 0.875rem;
    }

    th {
        font-family: var(--font-mono);
        font-weight: 400;
        color: var(--zinc-400);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }

    td {
        font-variant-numeric: tabular-nums;
    }

    .op-cell {
        font-family: var(--font-sans) !important;
    }

    th:nth-child(n+2), td:nth-child(n+2) {
        text-align: right;
    }

    tr:last-child td { border-bottom: none; }

    .bench-note {
        text-align: right;
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .fact-content h3 { font-size: 1.25rem; }
        .facts-list { gap: 32px; }

        .table-container {
            border-radius: 0;
        }

        th, td {
            padding: 10px 12px;
            font-size: 0.75rem;
        }

        .bench-note {
            text-align: left;
        }
    }
</style>
