---
const docs = [
    { title: "Quickstart", href: "/docs/quickstart/", description: "Install, configure, and run your first sandbox in two minutes" },
    { title: "Self-Hosting", href: "/docs/self-hosting/", description: "Install the daemon on your own hardware" },
    { title: "CLI Reference", href: "/docs/reference/cli/", description: "Every command, global flags, environment variables" },
    { title: "API Reference", href: "/docs/reference/api/", description: "REST endpoints with curl examples" },
    { title: "Configuration", href: "/docs/reference/config/", description: "Server config, layered loading, data dir layout" },
    { title: "Architecture", href: "/docs/under-the-hood/architecture/", description: "System design, data flow, concurrency model" },
    { title: "Thermal States", href: "/docs/under-the-hood/thermal-states/", description: "Hot/warm/cold transitions and diff snapshots" },
    { title: "Networking", href: "/docs/under-the-hood/networking/", description: "Per-user bridges, TAP devices, kernel ip=" },
    { title: "Wire Protocol", href: "/docs/under-the-hood/wire-protocol/", description: "Binary framing, connection lifecycle, auth" },
];
---

<section id="docs">
    <div class="container">
        <span class="system-label">SYS.DOCUMENTATION</span>
        <h2 class="section-heading mb-64">Documentation</h2>

        <div class="docs-grid">
            {docs.map(doc => (
                <a href={doc.href} class="doc-card">
                    <h3>{doc.title}</h3>
                    <p>{doc.description}</p>
                    <span class="doc-arrow">→</span>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .docs-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .doc-card {
        display: flex;
        flex-direction: column;
        padding: 24px;
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        background: var(--zinc-900);
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
    }

    .doc-card:hover {
        border-color: var(--zinc-700);
        background: var(--zinc-800);
    }

    .doc-card h3 {
        font-size: 1rem;
        margin-bottom: 8px;
        font-family: var(--font-mono);
        color: var(--zinc-50);
    }

    .doc-card p {
        font-size: 0.8125rem;
        color: var(--zinc-400);
        line-height: 1.5;
        flex: 1;
    }

    .doc-arrow {
        position: absolute;
        top: 24px;
        right: 24px;
        color: var(--zinc-500);
        transition: color 0.2s, transform 0.2s;
    }

    .doc-card:hover .doc-arrow {
        color: var(--amber-500);
        transform: translateX(4px);
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .docs-grid {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .doc-card {
            padding: 16px 18px;
        }

        .doc-card h3 { font-size: 0.875rem; }
        .doc-card p { font-size: 0.75rem; }
    }
</style>
