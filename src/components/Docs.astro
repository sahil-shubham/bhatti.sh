---
const docs = [
    { title: "Quickstart", href: "/docs/quickstart/", description: "Install, create a sandbox, run your first command" },
    { title: "Architecture", href: "/docs/architecture/overview/", description: "System design, data flow, concurrency model" },
    { title: "Wire Protocol", href: "/docs/reference/wire-protocol/", description: "Binary framing, connection lifecycle, auth" },
    { title: "Guest Agent", href: "/docs/architecture/guest-agent/", description: "PID 1 init, PTY sessions, process management" },
    { title: "Thermal Management", href: "/docs/sandboxes/thermal/", description: "Hot/warm/cold states, diff snapshots" },
    { title: "Networking", href: "/docs/sandboxes/networking/", description: "Bridge architecture, IP allocation, proxy" },
    { title: "API Reference", href: "/docs/reference/cli/", description: "OpenAPI spec and CLI reference" },
    { title: "CLI Reference", href: "/docs/reference/cli/", description: "All commands and flags" },
    { title: "Testing", href: "/docs/contributing/testing/", description: "11K lines of tests, zero mocks for VM tests" },
];
---

<section id="docs">
    <div class="container">
        <span class="system-label">SYS.DOCUMENTATION</span>
        <h2 class="section-heading mb-64">Documentation</h2>

        <div class="docs-grid">
            {docs.map(doc => (
                <a href={doc.href} class="doc-card">
                    <h3>{doc.title}</h3>
                    <p>{doc.description}</p>
                    <span class="doc-arrow">→</span>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .docs-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .doc-card {
        display: flex;
        flex-direction: column;
        padding: 24px;
        border: 1px solid var(--border-color);
        border-radius: var(--border-radius);
        background: var(--bg-surface);
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
    }

    .doc-card:hover {
        border-color: var(--zinc-400);
        background: var(--bg-inset);
    }

    .doc-card h3 {
        font-size: 1rem;
        margin-bottom: 8px;
        font-family: var(--font-mono);
        color: var(--text-primary);
    }

    .doc-card p {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.5;
        flex: 1;
    }

    .doc-arrow {
        position: absolute;
        top: 24px;
        right: 24px;
        color: var(--text-muted);
        transition: color 0.2s, transform 0.2s;
    }

    .doc-card:hover .doc-arrow {
        color: var(--amber-500);
        transform: translateX(4px);
    }

    @media (max-width: 768px) {
        .section-heading { font-size: 1.75rem; }

        .docs-grid {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .doc-card {
            padding: 16px 18px;
        }

        .doc-card h3 { font-size: 0.875rem; }
        .doc-card p { font-size: 0.75rem; }
    }
</style>
