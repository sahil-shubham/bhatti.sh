<footer>
    <div class="container">
        <div class="footer-links">
            <a href="/">bhatti</a>
            <span>·</span>
            <span>open source</span>
            <span>·</span>
            <span>Apache 2.0</span>
            <span>·</span>
            <a href="https://github.com/sahil-shubham/bhatti" target="_blank" rel="noopener">GitHub</a>
            <span>·</span>
            <a href="https://github.com/sahil-shubham/bhatti/tree/main/docs" target="_blank" rel="noopener">Docs</a>
        </div>
        <div class="etymology">
            bhatti (भट्टी) — furnace. lohar (लोहार) — blacksmith.
        </div>
    </div>
</footer>

<style>
    footer {
        padding: 64px 0;
        border-top: 1px solid var(--zinc-800);
        text-align: center;
    }

    .footer-links {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-bottom: 24px;
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--zinc-400);
        flex-wrap: wrap;
    }

    .footer-links a {
        color: var(--zinc-400);
        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-links a:hover {
        color: var(--zinc-50);
    }

    .etymology {
        font-size: 0.75rem;
        color: var(--zinc-500);
        font-style: italic;
    }

    @media (max-width: 768px) {
        footer {
            padding: 40px 0;
        }

        .footer-links {
            gap: 10px;
            font-size: 0.75rem;
        }
    }
</style>
