---

---

<section id="architecture">
    <div class="container">
        <span class="system-label">SYS.ARCHITECTURE</span>
        <h2 class="section-heading mb-64">How it works</h2>

        <div class="diagram-container">
            <div class="arch-grid">
                <div class="arch-node">
                    <h4>Your Code</h4>
                    <p>CLI, REST API, WebSocket</p>
                </div>
                <div class="arch-connector"></div>
                <div class="arch-node highlight">
                    <h4>bhatti daemon</h4>
                    <ul>
                        <li>REST/WS API (:8080)</li>
                        <li>Thermal Manager</li>
                        <li>Multi-tenant Auth</li>
                        <li>SQLite + age encryption</li>
                    </ul>
                </div>
                <div class="arch-connector"></div>
                <div class="arch-node">
                    <h4>Firecracker microVM</h4>
                    <ul>
                        <li>Linux Kernel 6.1</li>
                        <li>Ubuntu 24.04 rootfs</li>
                        <li>lohar (PID 1) guest agent</li>
                        <li>TCP :1024 control / :1025 forward</li>
                    </ul>
                </div>
            </div>

            <div class="thermal-section">
                <span class="system-label">STATE.THERMAL_MANAGER</span>
                <div class="thermal-bar">
                    <div class="thermal-state">
                        <span>Hot</span>
                        <div class="timing">Active — executing</div>
                    </div>
                    <div class="thermal-state">
                        <span>Warm</span>
                        <div class="timing">Idle &gt; 30s · vCPUs paused · RAM held · ~400µs wake</div>
                    </div>
                    <div class="thermal-state">
                        <span>Cold</span>
                        <div class="timing">Idle &gt; 30m · Snapshotted to disk · RAM freed · ~50ms wake</div>
                    </div>
                </div>
                <p class="thermal-note text-xs text-muted mono">
                    Any API request transparently calls ensureHot() — consumers never see thermal state.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .section-heading {
        font-size: 2.5rem;
    }

    .diagram-container {
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        padding: 40px;
        background: var(--zinc-900);
    }

    .arch-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr auto 1.5fr;
        align-items: center;
        gap: 16px;
    }

    .arch-node {
        border: 1px solid var(--zinc-700);
        background: var(--zinc-950);
        padding: 16px;
        border-radius: var(--border-radius);
    }

    .arch-node.highlight {
        border-color: var(--amber-500);
        box-shadow: inset 0 0 20px rgba(249, 115, 22, 0.05);
    }

    .arch-node h4 {
        font-size: 0.875rem;
        margin-bottom: 8px;
        font-family: var(--font-mono);
    }

    .arch-node p {
        font-size: 0.75rem;
        color: var(--zinc-400);
        line-height: 1.4;
    }

    .arch-node ul {
        list-style: none;
        padding-left: 0;
        margin-top: 8px;
    }

    .arch-node li {
        font-size: 0.75rem;
        color: var(--zinc-400);
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 4px;
    }

    .arch-node li::before {
        content: '-';
        color: var(--zinc-700);
    }

    .arch-connector {
        height: 1px;
        width: 100%;
        background: repeating-linear-gradient(
            90deg,
            var(--zinc-700),
            var(--zinc-700) 4px,
            transparent 4px,
            transparent 8px
        );
    }

    .thermal-section {
        margin-top: 64px;
    }

    .thermal-bar {
        height: 80px;
        width: 100%;
        border-radius: var(--border-radius);
        background: linear-gradient(90deg,
            var(--amber-500) 0%,
            #a14107 40%,
            var(--zinc-800) 70%,
            var(--zinc-900) 100%);
        display: flex;
        position: relative;
        box-shadow: 0 0 40px rgba(249, 115, 22, 0.1);
        margin-top: 24px;
    }

    .thermal-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 16px;
        border-right: 1px solid rgba(0,0,0,0.2);
        position: relative;
    }

    .thermal-state:last-child { border-right: none; }

    .thermal-state span {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--zinc-50);
        text-transform: uppercase;
    }

    .thermal-state .timing {
        color: rgba(255,255,255,0.7);
        font-size: 0.65rem;
        margin-top: 4px;
    }

    .thermal-note {
        margin-top: 16px;
        text-align: center;
    }

    @media (max-width: 768px) {
        .arch-grid {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 8px;
        }

        .arch-connector {
            width: 1px;
            height: 16px;
            margin: 0 auto;
            background: repeating-linear-gradient(
                180deg,
                var(--zinc-700),
                var(--zinc-700) 4px,
                transparent 4px,
                transparent 8px
            );
        }

        .diagram-container {
            padding: 24px;
        }

        .thermal-state .timing {
            font-size: 0.6rem;
        }
    }
</style>
