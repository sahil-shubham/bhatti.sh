---
// Terminal animation — scripted demo inspired by deer.sh's ScriptedDemoEngine
// AI agent conversation with bottom input box, status bar, and tool calls
---

<div class="hero-terminal" id="hero-terminal">
    <div class="terminal-chrome">
        <div class="terminal-dots">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
        </div>
        <span class="terminal-title">bhatti</span>
    </div>
    <div id="hero-xterm"></div>
</div>

<style>
    .hero-terminal {
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
        height: 420px;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 700ms ease-out, transform 700ms ease-out;
    }

    .hero-terminal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .terminal-chrome {
        height: 40px;
        background: var(--zinc-900);
        border-bottom: 1px solid var(--zinc-800);
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 12px;
        flex-shrink: 0;
    }

    .terminal-dots {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .terminal-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--zinc-700);
    }

    .terminal-title {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--zinc-400);
    }

    #hero-xterm {
        flex: 1;
        min-height: 0;
        background: #09090b;
        overflow: hidden;
    }

    #hero-xterm :global(.xterm) {
        height: 100%;
        padding: 8px 0 0 0;
    }

    #hero-xterm :global(.xterm-viewport) {
        scrollbar-width: none;
    }

    #hero-xterm :global(.xterm-viewport::-webkit-scrollbar) {
        display: none;
    }

    @media (max-width: 768px) {
        .hero-terminal {
            height: 380px;
        }
    }
</style>

<script>
    import { Terminal } from '@xterm/xterm';
    import { FitAddon } from '@xterm/addon-fit';
    import '@xterm/xterm/css/xterm.css';

    // --- ANSI helpers ---
    const A = {
        rst:    '\x1b[0m',
        bold:   '\x1b[1m',
        italic: '\x1b[3m',
        dim:    '\x1b[2m',
        amber:  '\x1b[38;2;249;115;22m',
        green:  '\x1b[38;2;34;197;94m',
        cyan:   '\x1b[38;2;6;182;212m',
        red:    '\x1b[38;2;239;68;68m',
        muted:  '\x1b[38;2;113;113;122m',
        text:   '\x1b[38;2;228;228;231m',
        border: '\x1b[38;2;63;63;70m',
        olive:  '\x1b[38;2;163;190;140m',
        blue:   '\x1b[38;2;59;130;246m',
    } as const;

    const SPINNER = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
    const DOTS = ['', '.', '..', '...'];

    // --- Script actions ---
    type Action =
        | { type: 'type';    text: string }
        | { type: 'think';   ms: number }
        | { type: 'tool';    name: string; args?: string; result?: string }
        | { type: 'message'; content: string }
        | { type: 'pause';   ms: number };

    const SCRIPT: Action[] = [
        { type: 'type', text: 'set up a dev sandbox with node and run my test suite' },
        { type: 'think', ms: 2500 },
        { type: 'message', content: "I'll create a sandbox, install dependencies, and run your tests." },
        {
            type: 'tool',
            name: 'create_sandbox',
            args: 'name=dev, cpus=2, memory=1024',
            result: 'sandbox "dev" (a1b2c3d4) created in 3.2s',
        },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=node --version',
            result: 'v22.14.0',
        },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=npm install',
            result: 'added 847 packages in 4.2s',
        },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=npm test',
            result: 'Tests: 42 passed, 42 total. Time: 2.1s',
        },
        { type: 'think', ms: 1500 },
        { type: 'message', content: 'All 42 tests pass. Sandbox "dev" is ready — node v22.14.0, all deps installed.' },
        { type: 'pause', ms: 2000 },

        { type: 'type', text: 'nginx is returning 502 on web-prod-01, can you investigate?' },
        { type: 'think', ms: 2500 },
        { type: 'message', content: "I'll check the nginx logs and upstream config." },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=journalctl -u nginx --since "5m ago"',
            result: 'connect() failed (111: Connection refused) upstream',
        },
        {
            type: 'tool',
            name: 'read_file',
            args: 'sandbox=dev, path=/etc/nginx/conf.d/app.conf',
            result: 'upstream backend { server 127.0.0.1:3000; }',
        },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=ss -tlnp | grep 3000',
            result: '(empty — nothing listening on 3000)',
        },
        { type: 'think', ms: 2000 },
        { type: 'message', content: 'Found it — nginx proxies to :3000 but the app service crashed. Restarting it.' },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=systemctl restart app',
            result: '(started)',
        },
        {
            type: 'tool',
            name: 'exec',
            args: 'sandbox=dev, cmd=curl -s localhost/health',
            result: '{"status":"ok"}',
        },
        { type: 'message', content: 'Fixed — app service restarted, health check passes. The 502 was caused by port 3000 going down.' },

        { type: 'pause', ms: 8000 },
    ];

    // --- Engine ---
    class DemoEngine {
        private term: Terminal;
        private fitAddon: FitAddon;
        private destroyed = false;
        private timers: ReturnType<typeof setTimeout>[] = [];
        private thinkInterval: ReturnType<typeof setInterval> | null = null;
        private contentRow = 1;
        private mode: 'edit' | 'read-only' = 'edit';
        private sandboxId: string | null = null;
        private contextPct = 0;

        constructor(container: HTMLElement) {
            this.fitAddon = new FitAddon();
            this.term = new Terminal({
                cursorBlink: false,
                disableStdin: true,
                fontSize: 13,
                lineHeight: 1.4,
                fontFamily: "'Geist Mono', 'SF Mono', Menlo, monospace",
                theme: {
                    background: '#09090b',
                    foreground: '#e4e4e7',
                    cursor: '#09090b',
                    selectionBackground: '#3B82F640',
                    black: '#09090b',
                    red: '#ef4444',
                    green: '#22c55e',
                    yellow: '#eab308',
                    blue: '#3b82f6',
                    magenta: '#a855f7',
                    cyan: '#06b6d4',
                    white: '#d4d4d8',
                    brightBlack: '#71717a',
                    brightWhite: '#fafafa',
                },
                scrollback: 0,
                convertEol: true,
            });

            this.term.loadAddon(this.fitAddon);
            this.term.open(container);
            this.fitAddon.fit();

            const ro = new ResizeObserver(() => {
                this.fitAddon.fit();
                this.setupLayout();
            });
            ro.observe(container);

            this.run();
        }

        private delay(ms: number): Promise<void> {
            return new Promise(r => {
                const id = setTimeout(r, ms);
                this.timers.push(id);
            });
        }

        private writeLn(content: string) {
            this.term.writeln(content);
            const scrollBottom = (this.term.rows || 24) - 4;
            this.contentRow = Math.min(this.contentRow + 1, Math.max(scrollBottom, 1));
        }

        private setupLayout() {
            const rows = this.term.rows || 24;
            const scrollBottom = rows - 4;
            if (scrollBottom < 1) return;
            // Reserve bottom 4 rows: input box (top border + content + bottom border) + status
            this.term.write(`\x1b[1;${scrollBottom}r`);
            this.drawBottom();
            const row = Math.min(this.contentRow, scrollBottom);
            this.term.write(`\x1b[${row};1H`);
        }

        private drawBottom(inputText?: string) {
            const rows = this.term.rows || 24;
            const cols = this.term.cols || 80;
            const innerW = cols - 5; // "│ $ text │"

            this.term.write('\x1b[s'); // save cursor

            // --- Input box: top border ---
            this.term.write(`\x1b[${rows - 3};1H\x1b[2K`);
            this.term.write(`${A.border}\u256d${'\u2500'.repeat(cols - 2)}\u256e${A.rst}`);

            // --- Input box: content ---
            this.term.write(`\x1b[${rows - 2};1H\x1b[2K`);
            const prompt = `${A.amber}${A.bold}$${A.rst} `;
            const promptLen = 2;
            const maxLen = Math.max(1, innerW - promptLen);

            if (inputText) {
                const display = inputText.length > maxLen
                    ? inputText.slice(inputText.length - maxLen)
                    : inputText;
                const pad = Math.max(0, maxLen - display.length);
                this.term.write(
                    `${A.border}\u2502${A.rst} ${prompt}${A.text}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
                );
            } else {
                const placeholder = 'Type your message...';
                const display = placeholder.length > maxLen ? placeholder.slice(0, maxLen) : placeholder;
                const pad = Math.max(0, maxLen - display.length);
                this.term.write(
                    `${A.border}\u2502${A.rst} ${prompt}${A.muted}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
                );
            }

            // --- Input box: bottom border ---
            this.term.write(`\x1b[${rows - 1};1H\x1b[2K`);
            this.term.write(`${A.border}\u2570${'\u2500'.repeat(cols - 2)}\u256f${A.rst}`);

            // --- Status bar ---
            this.term.write(`\x1b[${rows};1H\x1b[2K`);

            const sep = `${A.muted} | ${A.rst}`;
            const parts: string[] = [];

            // Mode indicator
            if (this.mode === 'edit') {
                parts.push(`${A.green}${A.bold}EDIT${A.rst}`);
            } else {
                parts.push(`${A.amber}${A.bold}READ-ONLY${A.rst}`);
            }

            // Sandbox
            if (this.sandboxId) {
                parts.push(`${A.cyan}${this.sandboxId}${A.rst}`);
            } else {
                parts.push(`${A.muted}no sandbox${A.rst}`);
            }

            // Context bar
            if (cols >= 40) {
                const filled = Math.round(this.contextPct / 10);
                parts.push(
                    `${A.olive}[${'='.repeat(filled)}${' '.repeat(10 - filled)}]${A.rst} ${A.muted}${this.contextPct}%${A.rst}`
                );
            }

            // Engine label
            if (cols >= 60) {
                parts.push(`${A.muted}firecracker${A.rst}`);
            }

            this.term.write(` ${parts.join(sep)}`);

            this.term.write('\x1b[u'); // restore cursor
        }

        /** Echo user's message as a bordered box in the scroll region */
        private writeUserMessage(text: string) {
            const cols = this.term.cols || 80;
            const innerW = cols - 5;
            const display = text.length > innerW ? text.slice(0, innerW) : text;
            const pad = Math.max(0, innerW - display.length);
            this.writeLn(`${A.border}\u256d${'\u2500'.repeat(cols - 2)}\u256e${A.rst}`);
            this.writeLn(
                `${A.border}\u2502${A.rst} ${A.amber}${A.bold}$${A.rst} ${A.text}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
            );
            this.writeLn(`${A.border}\u2570${'\u2500'.repeat(cols - 2)}\u256f${A.rst}`);
            this.writeLn('');
        }

        /** Type text character-by-character into the bottom input box */
        private async typeInBox(text: string) {
            this.mode = 'edit';
            this.drawBottom();

            const rows = this.term.rows || 24;
            const cols = this.term.cols || 80;
            const innerW = cols - 5;
            const promptLen = 2;
            const maxLen = Math.max(1, innerW - promptLen);

            let typed = '';
            for (let i = 0; i < text.length; i++) {
                if (this.destroyed) return;
                typed += text[i];
                const display = typed.length > maxLen
                    ? typed.slice(typed.length - maxLen)
                    : typed;
                const pad = Math.max(0, maxLen - display.length);
                this.term.write(`\x1b[${rows - 2};1H\x1b[2K`);
                this.term.write(
                    `${A.border}\u2502${A.rst} ${A.amber}${A.bold}$${A.rst} ${A.text}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
                );
                await this.delay(45 + Math.random() * 30);
            }

            await this.delay(400);

            // Echo the user's message as a bordered box in scroll region
            const scrollBottom = (this.term.rows || 24) - 4;
            this.term.write(`\x1b[${Math.min(this.contentRow, scrollBottom)};1H`);
            this.writeUserMessage(text);

            // Switch to read-only, clear input
            this.mode = 'read-only';
            this.drawBottom();
        }

        /** Show an animated spinner */
        private startThinking() {
            if (this.thinkInterval) return;
            let frame = 0;
            let dotIdx = 0;
            const render = () => {
                const scrollBottom = (this.term.rows || 24) - 4;
                const row = Math.min(this.contentRow, scrollBottom);
                this.term.write(`\x1b[${row};1H\x1b[2K`);
                this.term.write(
                    `  ${A.amber}${SPINNER[frame % SPINNER.length]}${A.rst} ${A.muted}${A.italic}Thinking${DOTS[dotIdx % DOTS.length]}${A.rst}`
                );
            };
            render();
            this.thinkInterval = setInterval(() => {
                frame++;
                if (frame % 3 === 0) dotIdx++;
                render();
            }, 100);
        }

        private stopThinking() {
            if (this.thinkInterval) {
                clearInterval(this.thinkInterval);
                this.thinkInterval = null;
                const scrollBottom = (this.term.rows || 24) - 4;
                const row = Math.min(this.contentRow, scrollBottom);
                this.term.write(`\x1b[${row};1H\x1b[2K`);
            }
        }

        /** Write an assistant text message */
        private writeAssistantMessage(content: string) {
            const lines = content.split('\n');
            for (const line of lines) {
                this.writeLn(`${A.text}  ${line}${A.rst}`);
            }
            this.writeLn('');
        }

        /** Show tool call: pending phase */
        private writeToolStart(name: string, args?: string) {
            const argStr = args ? ` ${A.muted}${args}${A.rst}` : '';
            this.writeLn(`${A.muted}${A.italic}    ⋯ ${name}${argStr}${A.rst}`);
        }

        /** Show tool call: complete phase */
        private writeToolComplete(name: string, result?: string) {
            this.writeLn(`${A.cyan}    ✓ ${A.bold}${name}${A.rst}`);
            if (result != null) {
                const maxLen = 200;
                const display = result.length > maxLen ? result.slice(0, maxLen) + '…' : result;
                this.writeLn(`${A.muted}      → ${display}${A.rst}`);
            }
        }

        private async runAction(action: Action) {
            if (this.destroyed) return;
            switch (action.type) {
                case 'type':
                    this.contextPct = Math.min(100, this.contextPct + 3);
                    await this.typeInBox(action.text);
                    break;
                case 'think':
                    this.startThinking();
                    await this.delay(action.ms);
                    this.stopThinking();
                    break;
                case 'tool':
                    this.contextPct = Math.min(100, this.contextPct + 2);
                    this.writeToolStart(action.name, action.args);
                    await this.delay(800 + Math.random() * 500);
                    this.writeToolComplete(action.name, action.result);

                    // Track sandbox state
                    if (action.name === 'create_sandbox' && action.result) {
                        const match = action.result.match(/"([^"]+)"/);
                        if (match) this.sandboxId = match[1];
                    } else if (action.name === 'destroy_sandbox') {
                        this.sandboxId = null;
                    }
                    this.drawBottom();
                    await this.delay(400);
                    break;
                case 'message':
                    this.contextPct = Math.min(100, this.contextPct + 3);
                    this.writeAssistantMessage(action.content);
                    this.drawBottom();
                    await this.delay(600);
                    break;
                case 'pause':
                    await this.delay(action.ms);
                    break;
            }
        }

        private writeWelcome() {
            this.writeLn('');
            this.writeLn(`  ${A.amber}${A.bold}bhatti${A.rst} ${A.muted}v0.1.0${A.rst}`);
            this.writeLn(`  ${A.muted}Self-hosted sandbox orchestrator${A.rst}`);
            this.writeLn('');
        }

        private async run() {
            while (!this.destroyed) {
                this.mode = 'edit';
                this.sandboxId = null;
                this.contextPct = 0;
                this.contentRow = 1;
                this.term.clear();
                this.term.reset();
                this.setupLayout();
                this.writeWelcome();

                for (const action of SCRIPT) {
                    if (this.destroyed) return;
                    await this.runAction(action);
                }
            }
        }

        destroy() {
            this.destroyed = true;
            this.stopThinking();
            for (const id of this.timers) clearTimeout(id);
            this.timers = [];
            this.term.dispose();
        }
    }

    // --- Init ---
    let engine: DemoEngine | null = null;

    function init() {
        const container = document.getElementById('hero-xterm');
        if (!container || engine) return;

        const wrapper = document.getElementById('hero-terminal');
        if (wrapper) {
            requestAnimationFrame(() => wrapper.classList.add('visible'));
        }

        setTimeout(() => {
            if (!container || engine) return;
            engine = new DemoEngine(container);
        }, 700);
    }

    const obs = new IntersectionObserver(entries => {
        if (entries[0]?.isIntersecting) { init(); obs.disconnect(); }
    }, { threshold: 0.1 });
    const el = document.getElementById('hero-terminal');
    if (el) obs.observe(el);
</script>
