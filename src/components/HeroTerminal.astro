---
// Terminal animation — scripted demo inspired by deer.sh's ScriptedDemoEngine
// Single continuous flow with bottom input box, status bar, and thinking spinner
---

<div class="hero-terminal" id="hero-terminal">
    <div class="terminal-chrome">
        <div class="terminal-dots">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
        </div>
        <span class="terminal-title">bhatti</span>
    </div>
    <div id="hero-xterm"></div>
</div>

<style>
    .hero-terminal {
        border: 1px solid var(--zinc-800);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
        height: 400px;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 700ms ease-out, transform 700ms ease-out;
    }

    .hero-terminal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .terminal-chrome {
        height: 40px;
        background: var(--zinc-900);
        border-bottom: 1px solid var(--zinc-800);
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 12px;
        flex-shrink: 0;
    }

    .terminal-dots {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .terminal-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--zinc-700);
    }

    .terminal-title {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--zinc-400);
    }

    #hero-xterm {
        flex: 1;
        min-height: 0;
        background: #09090b;
        overflow: hidden;
    }

    #hero-xterm :global(.xterm) {
        height: 100%;
        padding: 8px 0 0 0;
    }

    #hero-xterm :global(.xterm-viewport) {
        scrollbar-width: none;
    }

    #hero-xterm :global(.xterm-viewport::-webkit-scrollbar) {
        display: none;
    }

    @media (max-width: 768px) {
        .hero-terminal {
            height: 350px;
        }
    }
</style>

<script>
    import { Terminal } from '@xterm/xterm';
    import { FitAddon } from '@xterm/addon-fit';
    import '@xterm/xterm/css/xterm.css';

    // --- ANSI helpers ---
    const A = {
        rst:    '\x1b[0m',
        bold:   '\x1b[1m',
        italic: '\x1b[3m',
        dim:    '\x1b[2m',
        amber:  '\x1b[38;2;249;115;22m',
        green:  '\x1b[38;2;34;197;94m',
        cyan:   '\x1b[38;2;6;182;212m',
        red:    '\x1b[38;2;239;68;68m',
        muted:  '\x1b[38;2;113;113;122m',
        text:   '\x1b[38;2;228;228;231m',
        border: '\x1b[38;2;63;63;70m',
        olive:  '\x1b[38;2;163;190;140m',
    } as const;

    const SPINNER = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
    const DOTS = ['', '.', '..', '...'];

    // --- Script actions ---
    type Action =
        | { type: 'cmd';     text: string }
        | { type: 'out';     text: string }
        | { type: 'stream';  lines: string[]; interval: number }
        | { type: 'think';   ms: number; label?: string }
        | { type: 'pause';   ms: number }
        | { type: 'status';  sandbox?: string | null; state?: string };

    const SCRIPT: Action[] = [
        // --- Create sandbox ---
        { type: 'status', sandbox: null, state: 'ready' },
        { type: 'cmd', text: 'bhatti create --name dev --cpus 2 --memory 1024' },
        { type: 'think', ms: 3200, label: 'Booting microVM' },
        { type: 'status', sandbox: 'dev', state: 'running' },
        { type: 'out', text: `${A.green}✓${A.rst} Created sandbox ${A.dim}"dev"${A.rst} (a1b2c3d4) in ${A.text}3.2s${A.rst}` },
        { type: 'pause', ms: 600 },

        // --- Quick exec ---
        { type: 'cmd', text: 'bhatti exec dev -- uname -a' },
        { type: 'think', ms: 80 },
        { type: 'out', text: 'Linux dev 6.1.155 #1 SMP x86_64 GNU/Linux' },
        { type: 'pause', ms: 400 },

        { type: 'cmd', text: 'bhatti exec dev -- node -e "console.log(\'hello from firecracker\')"' },
        { type: 'think', ms: 100 },
        { type: 'out', text: 'hello from firecracker' },
        { type: 'pause', ms: 500 },

        { type: 'cmd', text: 'bhatti exec dev -- cat /etc/os-release | head -2' },
        { type: 'think', ms: 60 },
        { type: 'out', text: 'PRETTY_NAME="Ubuntu 24.04.2 LTS"' },
        { type: 'out', text: 'NAME="Ubuntu"' },
        { type: 'pause', ms: 600 },

        // --- Streaming exec: npm install ---
        { type: 'cmd', text: 'bhatti exec dev -- npm install express' },
        { type: 'think', ms: 300 },
        { type: 'stream', interval: 400, lines: [
            `${A.dim}added 65 packages in 2.1s${A.rst}`,
            '',
            `${A.dim}14 packages are looking for funding${A.rst}`,
            `${A.dim}  run \`npm fund\` for details${A.rst}`,
        ]},
        { type: 'pause', ms: 500 },

        // --- Shell into sandbox ---
        { type: 'cmd', text: 'bhatti shell dev' },
        { type: 'think', ms: 200, label: 'Connecting' },
        { type: 'status', state: 'shell' },
        { type: 'out', text: `${A.dim}Connected to ${A.text}dev${A.dim} (a1b2c3d4)${A.rst}` },
        { type: 'pause', ms: 300 },

        { type: 'cmd', text: 'ls' },
        { type: 'think', ms: 40 },
        { type: 'out', text: `${A.green}node_modules${A.rst}  package.json  package-lock.json  ${A.green}src${A.rst}` },
        { type: 'pause', ms: 400 },

        { type: 'cmd', text: 'npm run build' },
        { type: 'think', ms: 200 },
        { type: 'stream', interval: 500, lines: [
            '> build',
            '> tsc && node esbuild.js',
            '',
            `${A.green}✓${A.rst} compiled 847 modules in 2.1s`,
        ]},
        { type: 'pause', ms: 600 },

        // --- Detach ---
        { type: 'out', text: '' },
        { type: 'out', text: `${A.amber}[detached — Ctrl+\\]${A.rst}` },
        { type: 'status', state: 'ready' },
        { type: 'pause', ms: 800 },

        // --- Auto-pause & instant resume ---
        { type: 'out', text: `${A.muted}${A.italic}  sandbox auto-paused after 30s idle (vCPUs frozen)${A.rst}` },
        { type: 'status', state: 'paused' },
        { type: 'pause', ms: 1200 },

        { type: 'cmd', text: 'bhatti exec dev -- echo "instant"' },
        { type: 'think', ms: 50 },
        { type: 'status', state: 'running' },
        { type: 'out', text: `${A.dim}[warm → hot in 0.4ms]${A.rst}` },
        { type: 'out', text: 'instant' },
        { type: 'pause', ms: 600 },

        { type: 'cmd', text: 'bhatti exec dev -- echo "1ms exec on a real VM"' },
        { type: 'think', ms: 50 },
        { type: 'out', text: '1ms exec on a real VM' },

        { type: 'pause', ms: 8000 },
    ];

    // --- Engine ---
    class DemoEngine {
        private term: Terminal;
        private fitAddon: FitAddon;
        private destroyed = false;
        private timers: ReturnType<typeof setTimeout>[] = [];
        private thinkInterval: ReturnType<typeof setInterval> | null = null;
        private contentRow = 1;
        private sandbox: string | null = null;
        private vmState = 'ready';
        private inShell = false;

        constructor(container: HTMLElement) {
            this.fitAddon = new FitAddon();
            this.term = new Terminal({
                cursorBlink: false,
                disableStdin: true,
                fontSize: 13,
                lineHeight: 1.4,
                fontFamily: "'Geist Mono', 'SF Mono', Menlo, monospace",
                theme: {
                    background: '#09090b',
                    foreground: '#e4e4e7',
                    cursor: '#09090b',
                    selectionBackground: '#3B82F640',
                    black: '#09090b',
                    red: '#ef4444',
                    green: '#22c55e',
                    yellow: '#eab308',
                    blue: '#3b82f6',
                    magenta: '#a855f7',
                    cyan: '#06b6d4',
                    white: '#d4d4d8',
                    brightBlack: '#71717a',
                    brightWhite: '#fafafa',
                },
                scrollback: 0,
                convertEol: true,
            });

            this.term.loadAddon(this.fitAddon);
            this.term.open(container);
            this.fitAddon.fit();

            const ro = new ResizeObserver(() => {
                this.fitAddon.fit();
                this.setupLayout();
            });
            ro.observe(container);

            this.run();
        }

        private delay(ms: number): Promise<void> {
            return new Promise(r => {
                const id = setTimeout(r, ms);
                this.timers.push(id);
            });
        }

        private writeLn(content: string) {
            this.term.writeln(content);
            const scrollBottom = (this.term.rows || 24) - 3;
            this.contentRow = Math.min(this.contentRow + 1, Math.max(scrollBottom, 1));
        }

        private setupLayout() {
            const rows = this.term.rows || 24;
            const scrollBottom = rows - 3;
            if (scrollBottom < 1) return;
            // Set scroll region — bottom 3 rows reserved for input box + status
            this.term.write(`\x1b[1;${scrollBottom}r`);
            this.drawBottom();
            const row = Math.min(this.contentRow, scrollBottom);
            this.term.write(`\x1b[${row};1H`);
        }

        private drawBottom(inputText?: string) {
            const rows = this.term.rows || 24;
            const cols = this.term.cols || 80;
            const innerW = cols - 4; // space for "│ $ ... │"

            this.term.write('\x1b[s'); // save cursor

            // --- Input box: top border ---
            this.term.write(`\x1b[${rows - 2};1H\x1b[2K`);
            this.term.write(`${A.border}\u256d${'\u2500'.repeat(cols - 2)}\u256e${A.rst}`);

            // --- Input box: content ---
            this.term.write(`\x1b[${rows - 1};1H\x1b[2K`);
            const prompt = this.inShell
                ? `${A.amber}${A.bold}lohar@${this.sandbox || 'dev'}:~$${A.rst} `
                : `${A.amber}${A.bold}$${A.rst} `;
            // Visible char count of prompt (no ANSI)
            const promptLen = this.inShell ? (this.sandbox || 'dev').length + 13 : 2;
            const maxLen = Math.max(1, innerW - promptLen);

            if (inputText) {
                const display = inputText.length > maxLen ? inputText.slice(inputText.length - maxLen) : inputText;
                const pad = Math.max(0, maxLen - display.length);
                this.term.write(
                    `${A.border}\u2502${A.rst} ${prompt}${A.text}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
                );
            } else {
                const placeholder = 'Type a command...';
                const display = placeholder.length > maxLen ? placeholder.slice(0, maxLen) : placeholder;
                const pad = Math.max(0, maxLen - display.length);
                this.term.write(
                    `${A.border}\u2502${A.rst} ${prompt}${A.muted}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
                );
            }

            // --- Status bar (integrates bottom border of input box) ---
            this.term.write(`\x1b[${rows};1H\x1b[2K`);

            const sep = `${A.muted} · ${A.rst}`;
            const parts: string[] = [];

            // Sandbox state dot
            if (this.sandbox) {
                const stateColor = this.vmState === 'running' || this.vmState === 'shell'
                    ? A.green
                    : this.vmState === 'paused' ? A.amber : A.muted;
                parts.push(`${stateColor}●${A.rst} ${A.text}${this.sandbox}${A.rst}`);
            } else {
                parts.push(`${A.muted}● no sandbox${A.rst}`);
            }

            // Mode badge
            if (this.inShell) {
                parts.push(`${A.cyan}SHELL${A.rst}`);
            }

            // Engine label
            if (cols >= 50) {
                parts.push(`${A.muted}firecracker${A.rst}`);
            }

            this.term.write(` ${A.border}\u2570\u2500${A.rst} ${parts.join(sep)}`);

            this.term.write('\x1b[u'); // restore cursor
        }

        /** Type text character-by-character into the bottom input box */
        private async typeInBox(text: string) {
            const rows = this.term.rows || 24;
            const cols = this.term.cols || 80;
            const innerW = cols - 4;
            const prompt = this.inShell
                ? `${A.amber}${A.bold}lohar@${this.sandbox || 'dev'}:~$${A.rst} `
                : `${A.amber}${A.bold}$${A.rst} `;
            const promptLen = this.inShell ? (this.sandbox || 'dev').length + 13 : 2;
            const maxLen = Math.max(1, innerW - promptLen);

            // Tokenize for natural chunked typing rhythm
            const tokens = text.match(/\S+|\s+/g) || [text];

            let typed = '';
            for (let t = 0; t < tokens.length; t++) {
                const token = tokens[t];
                for (const ch of token) {
                    if (this.destroyed) return;
                    typed += ch;
                    const display = typed.length > maxLen ? typed.slice(typed.length - maxLen) : typed;
                    const pad = Math.max(0, maxLen - display.length);
                    this.term.write(`\x1b[${rows - 1};1H\x1b[2K`);
                    this.term.write(
                        `${A.border}\u2502${A.rst} ${prompt}${A.text}${display}${A.rst}${' '.repeat(pad)} ${A.border}\u2502${A.rst}`
                    );
                    await this.delay(18 + Math.random() * 14);
                }
                // Inter-token pause (the "thinking" gap between words)
                if (t < tokens.length - 1 && !/^\s+$/.test(token)) {
                    await this.delay(50 + Math.random() * 80);
                }
            }

            await this.delay(300);

            // Echo the command into the scroll region
            const scrollBottom = (this.term.rows || 24) - 3;
            this.term.write(`\x1b[${Math.min(this.contentRow, scrollBottom)};1H`);

            const echoPrompt = this.inShell
                ? `${A.amber}lohar@${this.sandbox || 'dev'}:~$${A.rst} `
                : `${A.amber}$${A.rst} `;
            this.writeLn(`${echoPrompt}${A.text}${text}${A.rst}`);

            // Reset input box to placeholder
            this.drawBottom();
        }

        /** Show an animated spinner with optional label + dots */
        private startThinking(label?: string) {
            if (this.thinkInterval) return;
            let frame = 0;
            let dotIdx = 0;
            const lbl = label || 'Running';
            const render = () => {
                const scrollBottom = (this.term.rows || 24) - 3;
                const row = Math.min(this.contentRow, scrollBottom);
                this.term.write(`\x1b[${row};1H\x1b[2K`);
                this.term.write(
                    `  ${A.amber}${SPINNER[frame % SPINNER.length]}${A.rst} ${A.muted}${A.italic}${lbl}${DOTS[dotIdx % DOTS.length]}${A.rst}`
                );
            };
            render();
            this.thinkInterval = setInterval(() => {
                frame++;
                // Advance dots every ~4 spinner frames
                if (frame % 4 === 0) dotIdx++;
                render();
            }, 100);
        }

        private stopThinking() {
            if (this.thinkInterval) {
                clearInterval(this.thinkInterval);
                this.thinkInterval = null;
                const scrollBottom = (this.term.rows || 24) - 3;
                const row = Math.min(this.contentRow, scrollBottom);
                this.term.write(`\x1b[${row};1H\x1b[2K`);
            }
        }

        private async runAction(action: Action) {
            if (this.destroyed) return;
            switch (action.type) {
                case 'cmd':
                    await this.typeInBox(action.text);
                    break;
                case 'out':
                    this.writeLn(`  ${action.text}`);
                    break;
                case 'stream':
                    for (const line of action.lines) {
                        if (this.destroyed) return;
                        this.writeLn(`  ${line}`);
                        await this.delay(action.interval + Math.random() * action.interval * 0.3);
                    }
                    break;
                case 'think':
                    if (action.ms > 150) {
                        this.startThinking(action.label);
                        await this.delay(action.ms);
                        this.stopThinking();
                    } else {
                        await this.delay(action.ms);
                    }
                    break;
                case 'pause':
                    await this.delay(action.ms);
                    break;
                case 'status':
                    if (action.sandbox !== undefined) this.sandbox = action.sandbox;
                    if (action.state) this.vmState = action.state;
                    this.inShell = this.vmState === 'shell';
                    this.drawBottom();
                    break;
            }
        }

        private writeWelcome() {
            this.writeLn('');
            this.writeLn(`  ${A.amber}${A.bold}bhatti${A.rst} ${A.muted}v0.1.0${A.rst}`);
            this.writeLn(`  ${A.muted}Self-hosted sandbox orchestrator${A.rst}`);
            this.writeLn('');
        }

        private async run() {
            while (!this.destroyed) {
                this.sandbox = null;
                this.vmState = 'ready';
                this.inShell = false;
                this.contentRow = 1;
                this.term.clear();
                this.term.reset();
                this.setupLayout();
                this.writeWelcome();

                for (const action of SCRIPT) {
                    if (this.destroyed) return;
                    await this.runAction(action);
                }
            }
        }

        destroy() {
            this.destroyed = true;
            this.stopThinking();
            for (const id of this.timers) clearTimeout(id);
            this.timers = [];
            this.term.dispose();
        }
    }

    // --- Init ---
    let engine: DemoEngine | null = null;

    function init() {
        const container = document.getElementById('hero-xterm');
        if (!container || engine) return;

        const wrapper = document.getElementById('hero-terminal');
        if (wrapper) {
            requestAnimationFrame(() => wrapper.classList.add('visible'));
        }

        // Delay engine start until fade-in animation completes
        setTimeout(() => {
            if (!container || engine) return;
            engine = new DemoEngine(container);
        }, 700);
    }

    // Lazy init on visible
    const obs = new IntersectionObserver(entries => {
        if (entries[0]?.isIntersecting) { init(); obs.disconnect(); }
    }, { threshold: 0.1 });
    const el = document.getElementById('hero-terminal');
    if (el) obs.observe(el);
</script>
