---
// Single continuous terminal demo — no tabs, one story
---

<div class="hero-terminal" id="hero-terminal">
    <div class="terminal-chrome">
        <div class="terminal-dots">
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
            <div class="terminal-dot"></div>
        </div>
        <span class="terminal-title">bhatti</span>
    </div>
    <div id="hero-xterm"></div>
</div>

<style>
    .hero-terminal {
        border: 1px solid var(--zinc-800);
        border-radius: var(--border-radius);
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
        height: 380px;
    }

    .terminal-chrome {
        height: 36px;
        background: var(--zinc-900);
        border-bottom: 1px solid var(--zinc-800);
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 16px;
        flex-shrink: 0;
    }

    .terminal-dots {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .terminal-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--zinc-700);
    }

    .terminal-title {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        color: var(--zinc-500);
    }

    #hero-xterm {
        flex: 1;
        min-height: 0;
        background: #000000;
        overflow: hidden;
    }

    #hero-xterm :global(.xterm) {
        height: 100%;
        padding: 12px 0 12px 12px;
    }

    @media (max-width: 768px) {
        #hero-xterm :global(.xterm) {
            padding: 8px 0 8px 8px;
        }
    }

    #hero-xterm :global(.xterm-viewport) {
        background: #000000 !important;
        scrollbar-width: none;
    }

    #hero-xterm :global(.xterm-viewport::-webkit-scrollbar) {
        display: none;
    }

    @media (max-width: 768px) {
        .hero-terminal {
            height: 320px;
        }
    }
</style>

<script>
    import { Terminal } from '@xterm/xterm';
    import { FitAddon } from '@xterm/addon-fit';
    import '@xterm/xterm/css/xterm.css';

    // --- ANSI codes ---
    const DIM = '\x1b[2m';
    const RST = '\x1b[0m';
    const AMB = '\x1b[38;5;208m';
    const GRN = '\x1b[32m';
    const RED = '\x1b[31m';
    const PROMPT = `${AMB}\$${RST} `;
    const CARET_CH = '▋';
    const CARET = `\x1b[s\x1b[38;5;208m${CARET_CH}\x1b[0m\x1b[u`; // draw caret, return to position
    const CLEAR_CARET = `\x1b[s \x1b[u`; // overwrite caret with space, return

    const SPINNER = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];

    // --- Action types ---
    type Action =
        | { type: 'cmd'; text: string }
        | { type: 'out'; text: string }
        | { type: 'spinner'; label: string; ms: number; done: string }
        | { type: 'wait'; ms: number }
        | { type: 'comment'; text: string }
        | { type: 'stream'; lines: string[]; interval: number };

    // --- The script ---
    //
    // Timings here track the bench/results numbers from agni-01
    // (Hetzner AX102, btrfs, bhatti v1.11.0). Numbers shown to the user
    // are CLI wall-clock for ops we measured directly; spinner durations
    // (`ms`) are tuned to roughly match real wall-clock so the animation
    // doesn't pretend things are faster than they are.
    // Output strings track the real CLI's printf format strings in
    // cmd/bhatti/{sandbox,snapshot,image,misc}_cmd.go. Spinner durations
    // mirror the bench/results numbers from agni-01 (v1.11.0).
    const SCRIPT: Action[] = [
        // 1. Create a machine. Real: 268ms p50.
        { type: 'cmd', text: 'bhatti create --name dev --cpus 2 --memory 1024' },
        { type: 'spinner', label: 'Booting...', ms: 280,
          done: 'sandbox/dev created (2 vCPU, 1024 MB)' },
        { type: 'out', text: '  IP:    10.0.1.4' },
        { type: 'out', text: '  Shell: bhatti shell dev' },
        { type: 'wait', ms: 400 },

        // 2. Start a server inside it (detached so exec returns).
        { type: 'cmd', text: "bhatti exec --detach dev -- node /workspace/server.js" },
        { type: 'wait', ms: 80 },
        { type: 'out', text: 'pid: 218' },
        { type: 'out', text: 'output: /tmp/bhatti-exec-a1b2c3d4.log' },
        { type: 'wait', ms: 500 },

        // 3. Hit it through the publish path — hot, ~2-3ms.
        { type: 'cmd', text: 'curl -s https://dev.bhatti.sh' },
        { type: 'wait', ms: 80 },
        { type: 'out', text: '{"visits":1}' },
        { type: 'wait', ms: 400 },

        { type: 'cmd', text: 'curl -s https://dev.bhatti.sh' },
        { type: 'wait', ms: 80 },
        { type: 'out', text: '{"visits":2}' },
        { type: 'wait', ms: 600 },

        // 4. Snapshot — captures running processes + memory.
        { type: 'comment', text: '# snapshot everything — processes, memory, state' },
        { type: 'cmd', text: 'bhatti snapshot create dev --name checkpoint' },
        { type: 'spinner', label: 'Snapshotting...', ms: 600,
          done: 'checkpoint "checkpoint" created (1024MB)' },
        { type: 'wait', ms: 500 },

        // 5. Kill the server (exec returns silently on exit 0).
        { type: 'cmd', text: 'bhatti exec dev -- pkill -f node' },
        { type: 'wait', ms: 200 },

        { type: 'cmd', text: 'curl -s https://dev.bhatti.sh' },
        { type: 'wait', ms: 100 },
        { type: 'out', text: `${RED}curl: (52) Empty reply from server${RST}` },
        { type: 'wait', ms: 800 },

        // 6. Destroy and restore from snapshot — process comes back with state intact.
        { type: 'cmd', text: 'bhatti destroy dev -y' },
        { type: 'wait', ms: 100 },
        { type: 'out', text: 'sandbox/dev destroyed' },
        { type: 'wait', ms: 300 },

        // Resume from named snapshot creates a NEW sandbox.
        // Real output is tab-separated: <id>\t<name>\t<ip>.
        { type: 'cmd', text: 'bhatti snapshot resume checkpoint --name dev' },
        { type: 'spinner', label: 'Restoring...', ms: 80,
          done: 'a1b2c3d4\tdev\t10.0.1.4' },
        { type: 'wait', ms: 300 },

        { type: 'cmd', text: 'curl -s https://dev.bhatti.sh' },
        { type: 'wait', ms: 80 },
        { type: 'out', text: `${GRN}{"visits":3}${RST}  ${DIM}# in-memory state survived${RST}` },
        { type: 'wait', ms: 800 },

        // 7. Save as reusable image.
        { type: 'cmd', text: 'bhatti image save dev --name my-app' },
        { type: 'spinner', label: 'Saving image...', ms: 300,
          done: 'saved "my-app" (1024MB)' },
        { type: 'wait', ms: 400 },

        // 8. Stamp out another machine from it.
        { type: 'cmd', text: 'bhatti create --name staging --image my-app' },
        { type: 'spinner', label: 'Booting...', ms: 280,
          done: 'sandbox/staging created (1 vCPU, 1024 MB)' },
        { type: 'out', text: '  IP:    10.0.1.6' },
        { type: 'out', text: '  Shell: bhatti shell staging' },
        { type: 'wait', ms: 400 },

        // 9. Publish to the internet (just a DB write — sub-ms).
        { type: 'cmd', text: 'bhatti publish staging -p 3000 -a staging' },
        { type: 'wait', ms: 60 },
        { type: 'out', text: `Published: ${GRN}https://staging.bhatti.sh${RST}` },
        { type: 'wait', ms: 600 },

        // 10. See all machines. Real CLI uses %-20s %-10s %-8s %-16s padding
        // for the list columns; we narrow them here so the URL column fits in
        // the hero terminal without wrapping. Same shape, tighter widths.
        { type: 'cmd', text: 'bhatti list' },
        { type: 'wait', ms: 100 },
        { type: 'stream', interval: 60, lines: [
            `${DIM}NAME      STATUS    THERMAL  IP          URL${RST}`,
            `staging   running   hot      10.0.1.6    https://staging.bhatti.sh`,
            `dev       running   ${AMB}cold${RST}     10.0.1.4    https://dev.bhatti.sh`,
        ]},
        { type: 'wait', ms: 800 },

        // 11. Wake a sleeping machine — cold sandbox, request triggers transparent wake.
        // Real cold-wake-via-publish: ~60ms p50.
        { type: 'cmd', text: 'curl -s https://dev.bhatti.sh' },
        { type: 'wait', ms: 60 },
        { type: 'out', text: `${DIM}# transparent wake from cold (~60ms)${RST}` },
        { type: 'out', text: `${GRN}{"visits":4}${RST}` },

        // End pause before loop
        { type: 'wait', ms: 6000 },
    ];

    // --- Engine ---
    class BhattiDemo {
        private term: Terminal;
        private fitAddon: FitAddon;
        private destroyed = false;
        private timers: ReturnType<typeof setTimeout>[] = [];
        private spinnerInterval: ReturnType<typeof setInterval> | null = null;

        constructor(container: HTMLElement) {
            this.fitAddon = new FitAddon();
            const mobile = window.innerWidth <= 768;
            this.term = new Terminal({
                cursorBlink: false,
                cursorStyle: 'block',
                cursorInactiveStyle: 'block',
                disableStdin: true,
                fontSize: mobile ? 10 : 13,
                lineHeight: 1.4,
                fontFamily: "'Geist Mono', 'SF Mono', Menlo, monospace",
                theme: {
                    background: '#000000',
                    foreground: '#e4e4e7',
                    cursor: '#F97316',
                    black: '#3f3f46', red: '#ef4444', green: '#22c55e', yellow: '#eab308',
                    blue: '#3b82f6', magenta: '#a855f7', cyan: '#06b6d4', white: '#d4d4d8',
                    brightBlack: '#71717a', brightWhite: '#fafafa',
                },
                scrollback: 200,
                convertEol: true,
            });

            this.term.loadAddon(this.fitAddon);
            this.term.open(container);
            this.fitAddon.fit();
            // Hide xterm's built-in cursor entirely
            this.term.write('\x1b[?25l');

            let rt: number;
            window.addEventListener('resize', () => {
                clearTimeout(rt);
                rt = window.setTimeout(() => this.fitAddon.fit(), 150);
            });

            this.run();
        }

        private delay(ms: number): Promise<void> {
            return new Promise((resolve, reject) => {
                if (this.destroyed) { reject(new DOMException('', 'AbortError')); return; }
                const id = setTimeout(resolve, ms);
                this.timers.push(id);
            });
        }

        private async typeCmd(text: string) {
            this.term.write(PROMPT);
            // Show initial caret at prompt
            this.term.write(CARET);

            const tokens = text.match(/\S+|\s+/g) || [text];
            for (let i = 0; i < tokens.length; i++) {
                const token = tokens[i];
                for (const ch of token) {
                    if (this.destroyed) return;
                    // Write char (overwrites caret), draw caret ahead
                    this.term.write(ch + CARET);
                    await this.delay(14 + Math.random() * 14);
                }
                // pause between non-whitespace tokens
                if (i < tokens.length - 1 && !/^\s+$/.test(token)) {
                    await this.delay(40 + Math.random() * 80);
                }
            }

            // Clear caret, newline
            this.term.write(CLEAR_CARET);
            this.term.write('\r\n');
        }

        private async showSpinner(label: string, ms: number, done: string) {
            let frame = 0;
            this.term.write(`  ${DIM}${SPINNER[0]} ${label}${RST}`);

            this.spinnerInterval = setInterval(() => {
                frame = (frame + 1) % SPINNER.length;
                this.term.write(`\r\x1b[2K  ${DIM}${SPINNER[frame]} ${label}${RST}`);
            }, 80);

            await this.delay(ms);

            if (this.spinnerInterval) {
                clearInterval(this.spinnerInterval);
                this.spinnerInterval = null;
            }
            this.term.write(`\r\x1b[2K  ${GRN}✓${RST} ${done}\r\n`);
        }

        private async runAction(action: Action) {
            if (this.destroyed) return;

            switch (action.type) {
                case 'cmd':
                    await this.typeCmd(action.text);
                    break;
                case 'out':
                    this.term.writeln(action.text);
                    break;
                case 'spinner':
                    await this.showSpinner(action.label, action.ms, action.done);
                    break;
                case 'wait':
                    await this.delay(action.ms);
                    break;
                case 'comment':
                    this.term.writeln(`${DIM}${action.text}${RST}`);
                    break;
                case 'stream':
                    for (const line of action.lines) {
                        if (this.destroyed) return;
                        this.term.writeln(line);
                        await this.delay(action.interval + Math.random() * action.interval * 0.3);
                    }
                    break;
            }
        }

        private async run() {
            while (!this.destroyed) {
                this.term.reset();
                this.term.write('\x1b[?25l');

                try {
                    for (const action of SCRIPT) {
                        if (this.destroyed) return;
                        await this.runAction(action);
                    }
                } catch (e) {
                    if ((e as DOMException).name !== 'AbortError') throw e;
                }
            }
        }

        destroy() {
            this.destroyed = true;
            if (this.spinnerInterval) {
                clearInterval(this.spinnerInterval);
                this.spinnerInterval = null;
            }
            for (const id of this.timers) clearTimeout(id);
            this.timers = [];
            this.term.dispose();
        }
    }

    // --- Init on visible ---
    let demo: BhattiDemo | null = null;

    const obs = new IntersectionObserver(entries => {
        if (entries[0]?.isIntersecting) {
            const container = document.getElementById('hero-xterm');
            if (container && !demo) {
                demo = new BhattiDemo(container);
            }
            obs.disconnect();
        }
    }, { threshold: 0.1 });

    const el = document.getElementById('hero-terminal');
    if (el) obs.observe(el);
</script>
